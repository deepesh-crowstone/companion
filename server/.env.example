# Copy this file to .env (same folder). No quotes around values.
# Get key: https://console.x.ai/team/default/api-keys
XAI_API_KEY=xai-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
JWT_SECRET=any-long-random-string-at-least-32-chars
XAI_CHAT_MODEL=grok-4.3
# Voice notes use xAI STT + Grok reply + ElevenLabs TTS by default.
# Use text_tagged to experiment with normal text-chat chunks joined into voice notes.
MIA_VOICE_REPLY_PIPELINE=voice
MIA_TTS_PROVIDER=elevenlabs
ELEVENLABS_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ELEVENLABS_VOICE_ID=your_elevenlabs_voice_id
ELEVENLABS_MODEL_ID=eleven_v3
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128
ELEVENLABS_STABILITY=0.45
ELEVENLABS_SIMILARITY_BOOST=0.8
ELEVENLABS_STYLE=0
ELEVENLABS_SPEAKER_BOOST=true
# xAI voice fallback when MIA_TTS_PROVIDER=xai, and realtime calls.
MIA_VOICE_ID=eve
# Voice notes: Hindi voice/accent for Devanagari Hindi replies (xAI BCP-47).
MIA_TTS_LANGUAGE=hi
MIA_STT_LANGUAGE=hi
PORT=3000
HOST=0.0.0.0

# PostgreSQL (local example)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mia

# Railway Bucket — required for voice notes and private-mode photos (same bucket).
# BUCKET=my-bucket-xxxxx
# ENDPOINT=https://storage.railway.app
# REGION=auto
# ACCESS_KEY_ID=
# SECRET_ACCESS_KEY=
# After bucket is configured, upload gallery once: npm run seed:zara-photos
# Objects: voice/* (recordings), photos/zara/*.jpg (Zara private chat photos)

# Cashfree Payment Gateway (personality pass)
# Dashboard: https://merchant.cashfree.com/merchants/pg/developers/api-keys
CASHFREE_ENV=sandbox
CASHFREE_CLIENT_ID=
CASHFREE_CLIENT_SECRET=
# Optional: webhook URL (e.g. https://api.chatlife.online/personalities/webhook)
# CASHFREE_NOTIFY_URL=

# Scripted call preview clips — JSON array of hosted MP3 URLs, played in order.
# Change on Railway (or .env) without an app update; the app fetches this list on each call tap.
# CALL_PREVIEW_AUDIO_URLS=["https://cdn.example.com/zara/call_1.mp3","https://cdn.example.com/zara/call_2.mp3"]
